# ===========================================
# VPR7 — Переменные окружения (шаблон)
# Скопируйте в .env и заполните значения
# ===========================================

# ─── Деплой (SSH) ───
# Адрес сервера (хост)
DEPLOY_SSH_HOST=79.143.31.184
# Порт SSH (по умолчанию 22)
DEPLOY_SSH_PORT=22
# Пользователь SSH
DEPLOY_SSH_USER=root
# Путь к приватному ключу (опционально)
DEPLOY_SSH_KEY=../ssh-private.key
# Целевая директория на сервере (куда синхронизировать файлы)
DEPLOY_REMOTE_PATH=/var/www/vpr.nayanovaacademy.ru/public/
